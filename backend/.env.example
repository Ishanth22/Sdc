MONGO_URI=mongodb://localhost:27017/sdc
JWT_SECRET=your_super_secret_jwt_key_change_this

# AI Features (OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ─────────────────────────────────────────────
# 🚨 ALERT NOTIFICATIONS
# ─────────────────────────────────────────────

# Gmail (for email alerts)
# 1. Go to: https://myaccount.google.com/apppasswords
# 2. Create an App Password for "Mail"
# 3. Paste the 16-character code (with spaces) below
GMAIL_USER=your.gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Twilio (for SMS alerts)
# 1. Sign up free at: https://www.twilio.com/try-twilio
# 2. Get your Account SID, Auth Token and a free phone number
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
